{
  "name": "@package-kr/react-native-kakao-signin",
  "version": "1.0.7",
  "description": "React Native Kakao Login",
  "main": "src/index",
  "types": "src/index.ts",
  "scripts": {
    "android": "npm run android --workspace KakaoLoginCliExample",
    "ios": "npm run ios --workspace KakaoLoginCliExample --",
    "lint": "npm run lint --workspaces --if-present",
    "start": "npm run start --workspace KakaoLoginCliExample",
    "test": "npm run test --workspaces --if-present",
    "build:plugin": "tsc -p plugin/tsconfig.json",
    "prepublishOnly": "npm run build:plugin"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Package-KR/react-native-kakao-signin.git"
  },
  "files": [
    "src",
    "ios",
    "android",
    "plugin/build",
    "app.plugin.js",
    "*.podspec",
    "!KakaoLoginCliExample",
    "!android/build",
    "!ios/build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react-native",
    "kakao",
    "login"
  ],
  "license": "MIT",
  "workspaces": [
    "KakaoLoginCliExample"
  ],
  "devDependencies": {
    "@expo/config-plugins": "^9.0.0",
    "@types/node": "^25.6.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "codegenConfig": {
    "name": "RNKakaoSigninSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.packagekr.kakao"
    }
  }
}
