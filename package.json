{
  "name": "@package-kr/react-native-kakao-signin",
  "version": "2.1.0",
  "description": "React Native Kakao Signin",
  "main": "src/index",
  "types": "src/index.ts",
  "scripts": {
    "build:plugin": "tsc -p plugin/tsconfig.json",
    "prepublishOnly": "npm run build:plugin"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Package-KR/react-native-kakao-signin.git"
  },
  "files": [
    "src",
    "ios",
    "android",
    "plugin/build",
    "app.plugin.js",
    "*.podspec",
    "!example",
    "!android/build",
    "!ios/build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react-native",
    "kakao",
    "kakao-login",
    "kakao-signin",
    "kakao-sdk",
    "kakao-auth",
    "kakaotalk",
    "login",
    "signin",
    "oauth",
    "social-login",
    "expo",
    "expo-plugin",
    "turbomodule",
    "new-architecture",
    "ios",
    "android"
  ],
  "license": "MIT",
  "devDependencies": {
    "@expo/config-plugins": "^55.0.8",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "codegenConfig": {
    "name": "RNKakaoSigninSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "kr.packagekr.kakao.signin"
    }
  }
}
