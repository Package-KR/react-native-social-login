{
  "compilerOptions": {
    "lib": ["es2017"],
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es6",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "strict": true
  },
  "exclude": ["node_modules"],
  "include": ["src"]
}
